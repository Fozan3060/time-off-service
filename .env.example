# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=data/time-off.sqlite
# Use synchronize=true for quick iteration during development.
# Turn off for production and rely on migrations.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# HCM integration
HCM_BASE_URL=http://localhost:4000
HCM_API_KEY=dev-hcm-key
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
HCM_VERIFY_AFTER_WRITE=true

# Reconciliation
# Batch rows older than a recent SYNCED request by less than this
# many milliseconds are skipped to avoid clobbering in-flight state.
RECONCILIATION_GRACE_MS=30000
